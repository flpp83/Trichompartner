<main class="auth-layout-body">
  <section class="page-hero">
    <div class="container">
      <span class="tag">{{ section.settings.eyebrow }}</span>
      <h1>{{ section.settings.title }}</h1>
    </div>
  </section>
  <section class="section-tight">
    <div class="container">
      <div class="product-grid shop-product-grid">
        {% for collection in collections %}
          <article class="product-card shop-product-card">
            <div class="image">
              <a href="{{ collection.url }}">
                {% if collection.featured_image %}
                  {{ collection.featured_image | image_url: width: 640 | image_tag: alt: collection.title }}
                {% elsif collection.products.first.featured_image %}
                  {{ collection.products.first.featured_image | image_url: width: 640 | image_tag: alt: collection.title }}
                {% else %}
                  <img src="{{ 'assety-img-product.png' | asset_url }}" alt="{{ collection.title }}">
                {% endif %}
              </a>
            </div>
            <div class="copy">
              <h3><a href="{{ collection.url }}">{{ collection.title }}</a></h3>
              <p class="muted">{{ collection.products_count }} produktów</p>
            </div>
          </article>
        {% else %}
          <article class="product-card shop-product-card">
            <div class="copy">
              <h3>{{ section.settings.empty_title }}</h3>
              <p class="muted">{{ section.settings.empty_copy }}</p>
            </div>
          </article>
        {% endfor %}
      </div>
    </div>
  </section>
</main>

{% schema %}
{
  "name": "Main List Collections",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Kategorie"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Tytuł",
      "default": "Przeglądaj kolekcje"
    },
    {
      "type": "text",
      "id": "empty_title",
      "label": "Tytuł pustego stanu",
      "default": "Brak kolekcji"
    },
    {
      "type": "textarea",
      "id": "empty_copy",
      "label": "Opis pustego stanu",
      "default": "Dodaj kolekcje w Shopify, aby pokazać je w tym widoku."
    }
  ]
}
{% endschema %}
