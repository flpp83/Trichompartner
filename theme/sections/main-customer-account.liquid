<main class="auth-layout-body account-page">
  {% assign account_manager_name = settings.account_manager_name | default: 'Klaudia Nowak' %}
  <section class="page-hero">
    <div class="container">
      <span class="tag">{{ section.settings.eyebrow }}</span>
      <h1>{{ section.settings.title }}</h1>
      <p>{{ section.settings.lead }}</p>
    </div>
  </section>
  <section class="section-tight">
    <div class="container account-stats-grid">
      <article class="account-card account-stat-card">
        <h3>{{ section.settings.status_title }}</h3>
        <strong>{{ section.settings.status_value }}</strong>
        <p>{{ section.settings.status_copy }}</p>
      </article>
      <article class="account-card account-stat-card">
        <h3>{{ section.settings.manager_title }}</h3>
        <strong>{{ account_manager_name }}</strong>
        <p>{{ section.settings.manager_copy }}</p>
      </article>
      <article class="account-card account-stat-card">
        <h3>{{ section.settings.orders_title }}</h3>
        <strong>{{ customer.orders_count }}</strong>
        <p>{{ section.settings.orders_copy }}</p>
      </article>
    </div>
  </section>
  <section class="section-tight">
    <div class="container account-grid">
      <article class="account-card">
        <h3>{{ section.settings.account_details_title }}</h3>
        <table class="table">
          <tr><th>{{ section.settings.name_label }}</th><td>{{ customer.name }}</td></tr>
          <tr><th>{{ section.settings.email_label }}</th><td>{{ customer.email }}</td></tr>
          <tr><th>{{ section.settings.address_label }}</th><td>{% if customer.default_address %}{{ customer.default_address.address1 }}, {{ customer.default_address.city }}{% else %}{{ section.settings.empty_address_label }}{% endif %}</td></tr>
          <tr><th>{{ section.settings.status_label }}</th><td><span class="status-badge success">{{ section.settings.active_status_label }}</span></td></tr>
        </table>
      </article>
      <article class="account-card">
        <h3>{{ section.settings.actions_title }}</h3>
        <p style="margin-bottom:20px;">{{ section.settings.actions_copy }}</p>
        <div style="display:grid;gap:12px;">
          <a class="button" href="{{ routes.collections_url }}">{{ section.settings.primary_action_label }}</a>
          <a class="small-link" href="{{ settings.contact_page_url | default: '/pages/kontakt' }}">{{ section.settings.secondary_action_label }}</a>
          <a class="small-link" href="{{ routes.account_logout_url }}">{{ section.settings.logout_label }}</a>
        </div>
      </article>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="section-head"><div><h2>{{ section.settings.history_title }}</h2></div></div>
      <article class="account-card">
        <table class="table">
          <tr><th>{{ section.settings.order_number_label }}</th><th>{{ section.settings.order_date_label }}</th><th>{{ section.settings.order_status_label }}</th><th>{{ section.settings.order_total_label }}</th></tr>
          {% for order in customer.orders %}
            <tr>
              <td>{{ order.name }}</td>
              <td>{{ order.created_at | date: '%d.%m.%Y' }}</td>
              <td>{{ order.fulfillment_status_label }}</td>
              <td>{{ order.total_price | money }}</td>
            </tr>
          {% else %}
            <tr><td colspan="4">{{ section.settings.empty_orders_label }}</td></tr>
          {% endfor %}
        </table>
      </article>
    </div>
  </section>
</main>

